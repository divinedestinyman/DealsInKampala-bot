# Copy this to .env.local for development
# In Vercel: add these under Project Settings → Environment Variables

# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your Vercel deployment URL (set after first deploy)
# e.g. https://dealsin-kampala-bot.vercel.app
WEBHOOK_URL=https://your-vercel-url.vercel.app

# Secret token to verify webhook requests are from Telegram
# Generate any random string: openssl rand -hex 32
WEBHOOK_SECRET=your_random_secret_here
